# InsForge Configuration
# Get these values from your InsForge dashboard: https://insforge.dev

# Your InsForge backend URL (required for authentication)
NEXT_PUBLIC_INSFORGE_BASE_URL=https://your-app.region.insforge.app

# Anonymous key (optional, only needed for database/storage operations)
NEXT_PUBLIC_INSFORGE_ANON_KEY=your_insforge_anon_key_here

# GymCRM open mode data source
# demo: API /api/gymcrm/* is internally rewritten to /api/gymcrm_open/* (sin login)
# live: usa backend real sin auth de InsForge en UI
GYMCRM_DATA_MODE=demo
# demo_all: muestra todos los portales para testeo demo
# role_scoped: oculta navegación no permitida por rol activo
NEXT_PUBLIC_GYMCRM_NAV_MODE=demo_all

# WhatsApp CTA for landing/CRM (E.164, without symbols)
NEXT_PUBLIC_GYMCRM_WHATSAPP_PHONE=59800000000

# E2E deterministic seed (Playwright)
E2E_SEED_ENABLED=true
E2E_OPEN_SESSION=true
# Required only if E2E_OPEN_SESSION=false (live auth mode):
E2E_ADMIN_API_KEY=your_project_admin_key
E2E_STAFF_EMAIL=staff@example.com
E2E_STAFF_PASSWORD=change_me
E2E_CLIENT_EMAIL=cliente@example.com
E2E_CLIENT_PASSWORD=change_me

# Optional rollout env mapping (staging/prod gates)
STAGING_BASE_URL=https://staging.your-app.region.insforge.app
PRODUCTION_BASE_URL=https://your-app.region.insforge.app
STAGING_E2E_ADMIN_API_KEY=your_staging_project_admin_key
STAGING_E2E_STAFF_EMAIL=staff-staging@example.com
STAGING_E2E_STAFF_PASSWORD=change_me
STAGING_E2E_CLIENT_EMAIL=cliente-staging@example.com
STAGING_E2E_CLIENT_PASSWORD=change_me
PROD_E2E_ADMIN_API_KEY=your_prod_project_admin_key
PROD_E2E_STAFF_EMAIL=staff-prod@example.com
PROD_E2E_STAFF_PASSWORD=change_me
PROD_E2E_CLIENT_EMAIL=cliente-prod@example.com
PROD_E2E_CLIENT_PASSWORD=change_me

# Smoke seed bridge
SMOKE_USE_SEED=true
SMOKE_SEED_OUTPUT=.playwright-artifacts/e2e-seed.json
